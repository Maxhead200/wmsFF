    "prisma:push": "prisma db push",
    "ensure:admin": "node dist/scripts/ensure-default-admin.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@prisma/client": "^6.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dejavu-fonts-ttf": "^2.37.3",
    "multer": "^1.4.5-lts.1",
    "pdfmake": "^0.3.11",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/pdfmake": "^0.3.3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
