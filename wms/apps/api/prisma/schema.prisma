generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum ClientStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ClientRequestType {
  INBOUND
  OUTBOUND
  RETURN
  DELIVERY
  SERVICE
  OTHER
}

enum ClientRequestStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  IN_WORK
  DONE
  CANCELLED
  REJECTED
}

enum ClientRequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum StockStatus {
  AVAILABLE
  RESERVED
  RECEIVING
  PACKING
  SHIPPING
  BLOCKED
  DEFECT
  QUARANTINE
  UNMARKED
  NEEDS_LABEL
  NEEDS_RELABEL
}

enum VolumeSource {
  MANUAL
  CALCULATED
  MARKETPLACE
  NOT_REQUIRED
}

enum MovementType {
  INITIAL_IMPORT
  RECEIPT
  MOVE
  RESERVE
  PICK
  PACK
  SHIP
  RETURN
  INVENTORY_ADJUSTMENT
}

enum TsdOperationStatus {
  ACCEPTED
  NEEDS_REVIEW
  REJECTED
}

enum TsdReviewAction {
  APPLY_INVENTORY_ADJUSTMENT
  REJECT
}

enum TsdDeviceStatus {
  ACTIVE
  BLOCKED
}

enum LogisticsPricingMode {
  TOTAL
  PER_PALLET
  MANUAL_REVIEW
}

enum BillingUnit {
  SERVICE
  PIECE
  BOX
  PALLET
  LITER
  DAY
  HOUR
}

enum BillingChargeStatus {
  DRAFT
  APPROVED
  CANCELLED
}

model User {
  id                     String          @id @default(uuid())
  email                  String          @unique
  passwordHash           String
  name                   String
  status                 UserStatus      @default(ACTIVE)
  roles                  UserRole[]
  clientScopes           UserClient[]
  tsdDevices             TsdDevice[]
  createdClientRequests  ClientRequest[] @relation("ClientRequestCreatedBy")
  assignedClientRequests ClientRequest[] @relation("ClientRequestAssignedTo")
  reviewedTsdOperations  TsdOperation[]  @relation("TsdOperationReviewedBy")
  createdBillingCharges  BillingCharge[] @relation("BillingChargeCreatedBy")
  approvedBillingCharges BillingCharge[] @relation("BillingChargeApprovedBy")
  auditLogs              AuditLog[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(uuid())
  code  String           @unique
  name  String
  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model UserClient {
  userId    String
  clientId  String
  canRead   Boolean  @default(true)
  canWrite  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, clientId])
  @@index([clientId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Client {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  inn            String?
  kpp            String?
  legalAddress   String?
  actualAddress  String?
  phone          String?
  email          String?
  status         ClientStatus    @default(ACTIVE)
  skus           Sku[]
  boxes          Box[]
  pallets        Pallet[]
  movements      StockMovement[]
  userScopes     UserClient[]
  requests       ClientRequest[]
  billingCharges BillingCharge[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  zones     Zone[]
  createdAt DateTime @default(now())
}

model Zone {
  id          String    @id @default(uuid())
  warehouseId String
  code        String
  name        String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  boxes       Box[]
  pallets     Pallet[]

  @@unique([warehouseId, code])
}

model Sku {
  id                 String              @id @default(uuid())
  clientId           String
  internalSku        String
  clientSku          String?
  article            String?
  name               String
  brand              String?
  category           String?
  color              String?
  size               String?
  weightGrams        Int?
  lengthCm           Decimal?            @db.Decimal(10, 2)
  widthCm            Decimal?            @db.Decimal(10, 2)
  heightCm           Decimal?            @db.Decimal(10, 2)
  volumeLiters       Decimal?            @db.Decimal(12, 3)
  volumeSource       VolumeSource        @default(CALCULATED)
  needsChestnyZnak   Boolean             @default(false)
  isUnmarked         Boolean             @default(false)
  needsLabel         Boolean             @default(false)
  needsRelabel       Boolean             @default(false)
  client             Client              @relation(fields: [clientId], references: [id])
  barcodes           Barcode[]
  movements          StockMovement[]
  balances           StockBalance[]
  clientRequestItems ClientRequestItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([clientId, internalSku])
}

model Barcode {
  id        String  @id @default(uuid())
  skuId     String
  value     String
  isPrimary Boolean @default(false)
  sku       Sku     @relation(fields: [skuId], references: [id])

  @@unique([skuId, value])
}

model Box {
  id        String          @id @default(uuid())
  clientId  String
  zoneId    String?
  palletId  String?
  code      String
  status    String          @default("active")
  client    Client          @relation(fields: [clientId], references: [id])
  zone      Zone?           @relation(fields: [zoneId], references: [id])
  pallet    Pallet?         @relation(fields: [palletId], references: [id])
  movements StockMovement[]
  balances  StockBalance[]

  @@unique([clientId, code])
}

model Pallet {
  id       String         @id @default(uuid())
  clientId String
  zoneId   String?
  code     String
  status   String         @default("active")
  client   Client         @relation(fields: [clientId], references: [id])
  zone     Zone?          @relation(fields: [zoneId], references: [id])
  boxes    Box[]
  balances StockBalance[]

  @@unique([clientId, code])
}

model StockMovement {
  id             String       @id @default(uuid())
  clientId       String
  skuId          String
  boxId          String?
  palletId       String?
  type           MovementType
  status         StockStatus
  quantity       Int
  sourceDocument String?
  idempotencyKey String?      @unique
  comment        String?
  client         Client       @relation(fields: [clientId], references: [id])
  sku            Sku          @relation(fields: [skuId], references: [id])
  box            Box?         @relation(fields: [boxId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([clientId, skuId, status])
  @@index([boxId])
}

model StockBalance {
  id         String      @id @default(uuid())
  balanceKey String      @unique
  clientId   String
  skuId      String
  boxId      String?
  palletId   String?
  status     StockStatus
  quantity   Int
  sku        Sku         @relation(fields: [skuId], references: [id])
  box        Box?        @relation(fields: [boxId], references: [id])
  pallet     Pallet?     @relation(fields: [palletId], references: [id])
  updatedAt  DateTime    @updatedAt

  @@index([clientId, skuId, status])
  @@index([boxId])
}

model ClientRequest {
  id               String                @id @default(uuid())
  clientId         String
  type             ClientRequestType
  status           ClientRequestStatus   @default(SUBMITTED)
  priority         ClientRequestPriority @default(NORMAL)
  title            String
  comment          String?
  contactName      String?
  contactPhone     String?
  deliveryAddress  String?
  desiredDate      DateTime?
  managerComment   String?
  createdByUserId  String?
  assignedToUserId String?
  client           Client                @relation(fields: [clientId], references: [id])
  createdBy        User?                 @relation("ClientRequestCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo       User?                 @relation("ClientRequestAssignedTo", fields: [assignedToUserId], references: [id])
  items            ClientRequestItem[]
  billingCharges   BillingCharge[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([clientId, status, createdAt])
  @@index([type, status])
  @@index([createdByUserId])
  @@index([assignedToUserId])
}

model ClientRequestItem {
  id        String        @id @default(uuid())
  requestId String
  skuId     String?
  barcode   String?
  name      String?
  quantity  Int
  comment   String?
  request   ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sku       Sku?          @relation(fields: [skuId], references: [id])

  @@index([requestId])
  @@index([skuId])
}

model BillingService {
  id              String          @id @default(uuid())
  code            String          @unique
  name            String
  unit            BillingUnit     @default(SERVICE)
  defaultPriceRub Decimal?        @db.Decimal(12, 2)
  isActive        Boolean         @default(true)
  charges         BillingCharge[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model BillingCharge {
  id               String              @id @default(uuid())
  clientId         String
  serviceId        String?
  requestId        String?
  description      String
  unit             BillingUnit         @default(SERVICE)
  quantity         Decimal             @db.Decimal(12, 3)
  unitPriceRub     Decimal             @db.Decimal(12, 2)
  totalRub         Decimal             @db.Decimal(14, 2)
  status           BillingChargeStatus @default(DRAFT)
  serviceDate      DateTime            @default(now())
  comment          String?
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  client           Client              @relation(fields: [clientId], references: [id])
  service          BillingService?     @relation(fields: [serviceId], references: [id])
  request          ClientRequest?      @relation(fields: [requestId], references: [id])
  createdBy        User?               @relation("BillingChargeCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy       User?               @relation("BillingChargeApprovedBy", fields: [approvedByUserId], references: [id])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([clientId, status, serviceDate])
  @@index([requestId])
  @@index([serviceId])
  @@index([approvedByUserId])
}

model LogisticsTariffSet {
  id         String               @id @default(uuid())
  name       String
  sourceFile String?
  note       String?
  activeFrom DateTime?
  activeTo   DateTime?
  directions LogisticsDirection[]
  createdAt  DateTime             @default(now())
}

model LogisticsDirection {
  id          String               @id @default(uuid())
  tariffSetId String
  origin      String
  destination String
  note        String?
  pricingMode LogisticsPricingMode @default(MANUAL_REVIEW)
  tariffSet   LogisticsTariffSet   @relation(fields: [tariffSetId], references: [id])
  tiers       LogisticsRateTier[]

  @@index([tariffSetId, origin, destination])
}

model LogisticsRateTier {
  id          String               @id @default(uuid())
  directionId String
  label       String
  minPallets  Int?
  maxPallets  Int?
  maxBoxes    Int?
  pricingMode LogisticsPricingMode @default(MANUAL_REVIEW)
  priceRub    Decimal              @db.Decimal(12, 2)
  direction   LogisticsDirection   @relation(fields: [directionId], references: [id])

  @@index([directionId])
}

model TsdOperation {
  id               String             @id @default(uuid())
  deviceId         String
  operationKey     String             @unique
  operationType    String
  payload          Json
  status           TsdOperationStatus @default(ACCEPTED)
  serverMessage    String?
  reviewAction     TsdReviewAction?
  reviewComment    String?
  reviewedByUserId String?
  reviewedBy       User?              @relation("TsdOperationReviewedBy", fields: [reviewedByUserId], references: [id])
  reviewedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([deviceId])
  @@index([reviewedAt])
  @@index([reviewedByUserId])
}

model TsdDevice {
  id          String          @id @default(uuid())
  code        String          @unique
  name        String
  secretHash  String
  status      TsdDeviceStatus @default(ACTIVE)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  lastLoginAt DateTime?
  lastSeenAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

model PrintJob {
  id          String   @id @default(uuid())
  printerCode String
  labelType   String
  payload     Json
  tspl        String
  status      String   @default("queued")
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  payload   Json?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
