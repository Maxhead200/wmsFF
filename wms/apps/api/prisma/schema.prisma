generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum ClientStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ClientKind {
  LEGAL_ENTITY
  INDIVIDUAL_ENTREPRENEUR
  SELF_EMPLOYED
  INDIVIDUAL
}

enum MarketplaceType {
  WILDBERRIES
  OZON
  YANDEX_MARKET
  SBER_MARKET
  OTHER
}

enum ClientRequestType {
  INBOUND
  OUTBOUND
  RETURN
  DELIVERY
  SERVICE
  OTHER
}

enum ClientRequestStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  IN_WORK
  PACKED
  DONE
  CANCELLED
  REJECTED
}

enum ClientRequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ClientRequestEventType {
  CREATED
  STATUS_CHANGED
  COMMENT
  FILE_UPLOADED
}

enum StockStatus {
  AVAILABLE
  RESERVED
  RECEIVING
  PACKING
  SHIPPING
  BLOCKED
  DEFECT
  QUARANTINE
  UNMARKED
  NEEDS_LABEL
  NEEDS_RELABEL
}

enum VolumeSource {
  MANUAL
  CALCULATED
  MARKETPLACE
  NOT_REQUIRED
}

enum MovementType {
  INITIAL_IMPORT
  RECEIPT
  MOVE
  RESERVE
  PICK
  PACK
  SHIP
  RETURN
  INVENTORY_ADJUSTMENT
}

enum PickWaveStatus {
  PLANNED
  PICKING
  DONE
  FAILED
  CANCELLED
}

enum PickWaveRequestStatus {
  PLANNED
  PICKED
  FAILED
}

enum TsdOperationStatus {
  ACCEPTED
  NEEDS_REVIEW
  REJECTED
}

enum TsdReviewAction {
  APPLY_INVENTORY_ADJUSTMENT
  REJECT
}

enum TsdReviewReason {
  INVENTORY_MISMATCH
  SKU_NOT_FOUND
  BOX_NOT_FOUND
  RECEIPT_FAILED
  DEVICE_MISMATCH
  VALIDATION_ERROR
  MANUAL_REJECT
  OTHER
}

enum TsdDeviceStatus {
  ACTIVE
  BLOCKED
}

enum LogisticsPricingMode {
  TOTAL
  PER_PALLET
  MANUAL_REVIEW
}

enum LogisticsDeliveryStatus {
  REQUESTED
  QUOTED
  PLANNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum LogisticsTripStatus {
  PLANNED
  LOADING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum BillingUnit {
  SERVICE
  PIECE
  BOX
  PALLET
  LITER
  LITER_DAY
  DAY
  HOUR
}

enum BillingChargeStatus {
  DRAFT
  APPROVED
  CANCELLED
}

enum BillingChargeSource {
  MANUAL
  STORAGE
  LOGISTICS
}

enum BillingInvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum BillingPriceTaxMode {
  INCLUDED
  ADD_6_PERCENT
}

enum BillingPaymentStatus {
  RECORDED
  CANCELLED
}

enum LabelTemplateType {
  BOX
  SKU
  PALLET
  CUSTOM
}

enum ClientNotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum ClientNotificationEvent {
  REQUEST_COMMENT
  REQUEST_STATUS_CHANGED
  REQUEST_FILE_UPLOADED
  BILLING_INVOICE_STATUS_CHANGED
  BILLING_PAYMENT_RECORDED
  LOGISTICS_DELIVERY_STATUS_CHANGED
  MANUAL
}

model User {
  id                             String                         @id @default(uuid())
  email                          String                         @unique
  passwordHash                   String
  name                           String
  status                         UserStatus                     @default(ACTIVE)
  roles                          UserRole[]
  clientScopes                   UserClient[]
  printerScopes                  UserPrinterGroup[]
  tsdDevices                     TsdDevice[]
  createdClientRequests          ClientRequest[]                @relation("ClientRequestCreatedBy")
  assignedClientRequests         ClientRequest[]                @relation("ClientRequestAssignedTo")
  reviewedTsdOperations          TsdOperation[]                 @relation("TsdOperationReviewedBy")
  createdBillingCharges          BillingCharge[]                @relation("BillingChargeCreatedBy")
  approvedBillingCharges         BillingCharge[]                @relation("BillingChargeApprovedBy")
  createdBillingInvoices         BillingInvoice[]               @relation("BillingInvoiceCreatedBy")
  createdBillingPayments         BillingPayment[]               @relation("BillingPaymentCreatedBy")
  updatedClientBillingServices   ClientBillingService[]         @relation("ClientBillingServiceUpdatedBy")
  createdDeliveries              LogisticsDeliveryRequest[]     @relation("LogisticsDeliveryCreatedBy")
  uploadedRequestFiles           ClientRequestFile[]            @relation("ClientRequestFileUploadedBy")
  createdRequestPackages         ClientRequestPackage[]         @relation("ClientRequestPackageCreatedBy")
  createdPickWaves               PickWave[]                     @relation("PickWaveCreatedBy")
  assignedPickWaves              PickWave[]                     @relation("PickWaveAssignedPicker")
  createdNotifications           ClientNotification[]           @relation("ClientNotificationCreatedBy")
  updatedNotificationPreferences ClientNotificationPreference[] @relation("ClientNotificationPreferenceUpdatedBy")
  authoredRequestComments        ClientRequestComment[]         @relation("ClientRequestCommentAuthor")
  createdRequestEvents           ClientRequestEvent[]           @relation("ClientRequestEventCreatedBy")
  assignedFulfillmentClients     Client[]                       @relation("ClientFulfillmentManager")
  auditLogs                      AuditLog[]
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(uuid())
  code  String           @unique
  name  String
  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model UserClient {
  userId    String
  clientId  String
  canRead   Boolean  @default(true)
  canWrite  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, clientId])
  @@index([clientId])
}

model UserPrinterGroup {
  userId    String
  groupCode String
  canPrint  Boolean  @default(true)
  canManage Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, groupCode])
  @@index([groupCode])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Client {
  id                       String                         @id @default(uuid())
  code                     String                         @unique
  name                     String
  clientKind               ClientKind                     @default(LEGAL_ENTITY)
  legalName                String?
  inn                      String?
  kpp                      String?
  ogrn                     String?
  legalAddress             String?
  actualAddress            String?
  phone                    String?
  email                    String?
  bankName                 String?
  bankBik                  String?
  bankAccount              String?
  correspondentAccount     String?
  storageAccountingEnabled Boolean                        @default(false)
  storagePriceRubPerLiterDay Decimal?                       @db.Decimal(12, 4)
  fulfillmentManagerUserId String?
  status                   ClientStatus                   @default(ACTIVE)
  fulfillmentManager       User?                          @relation("ClientFulfillmentManager", fields: [fulfillmentManagerUserId], references: [id])
  skus                     Sku[]
  boxes                    Box[]
  pallets                  Pallet[]
  movements                StockMovement[]
  userScopes               UserClient[]
  requests                 ClientRequest[]
  billingCharges           BillingCharge[]
  billingInvoices          BillingInvoice[]
  billingPayments          BillingPayment[]
  billingServicePrices      ClientBillingService[]
  deliveryRequests         LogisticsDeliveryRequest[]
  requestFiles             ClientRequestFile[]
  requestPackages          ClientRequestPackage[]
  notifications            ClientNotification[]
  notificationPreferences  ClientNotificationPreference[]
  marketplaceConnections   ClientMarketplaceConnection[]
  articleMappings          ClientArticleMapping[]
  productMarks             ProductMark[]
  requestComments          ClientRequestComment[]
  requestEvents            ClientRequestEvent[]
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt

  @@index([fulfillmentManagerUserId])
}

model ClientArticleMapping {
  id            String   @id @default(uuid())
  clientId      String
  sourceArticle String
  targetArticle String
  comment       String?
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([clientId, sourceArticle, targetArticle])
  @@index([clientId, targetArticle])
  @@index([clientId, sourceArticle])
}

model ClientMarketplaceConnection {
  id          String          @id @default(uuid())
  clientId    String
  marketplace MarketplaceType
  accountName String?
  sellerId    String?
  apiKey      String
  isActive    Boolean         @default(true)
  comment     String?
  client      Client          @relation(fields: [clientId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([clientId])
  @@unique([clientId, marketplace, accountName])
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  zones     Zone[]
  createdAt DateTime @default(now())
}

model Zone {
  id          String    @id @default(uuid())
  warehouseId String
  code        String
  name        String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  boxes       Box[]
  pallets     Pallet[]

  @@unique([warehouseId, code])
}

model Sku {
  id                 String                     @id @default(uuid())
  clientId           String
  internalSku        String
  clientSku          String?
  article            String?
  name               String
  brand              String?
  category           String?
  color              String?
  size               String?
  weightGrams        Int?
  lengthCm           Decimal?                   @db.Decimal(10, 2)
  widthCm            Decimal?                   @db.Decimal(10, 2)
  heightCm           Decimal?                   @db.Decimal(10, 2)
  volumeLiters       Decimal?                   @db.Decimal(12, 3)
  volumeSource       VolumeSource               @default(CALCULATED)
  needsChestnyZnak   Boolean                    @default(false)
  isUnmarked         Boolean                    @default(false)
  needsLabel         Boolean                    @default(false)
  needsRelabel       Boolean                    @default(false)
  marketplace        MarketplaceType?
  marketplaceProductId String?
  marketplaceOfferId String?
  marketplacePayload Json?
  marketplaceSyncedAt DateTime?
  client             Client                     @relation(fields: [clientId], references: [id])
  barcodes           Barcode[]
  movements          StockMovement[]
  balances           StockBalance[]
  clientRequestItems ClientRequestItem[]
  packageItems       ClientRequestPackageItem[]
  productMarks       ProductMark[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@unique([clientId, internalSku])
  @@index([clientId, marketplace, marketplaceProductId])
  @@index([clientId, marketplace, marketplaceOfferId])
}

model NomenclatureItem {
  id                 String   @id @default(uuid())
  internalSku        String   @unique
  article            String?
  barcode            String?  @unique
  name               String
  printName          String?
  unit               String?
  itemType           String?
  color              String?
  size               String?
  needsChestnyZnak   Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([name])
  @@index([article])
}

model Barcode {
  id        String  @id @default(uuid())
  skuId     String
  value     String
  isPrimary Boolean @default(false)
  sku       Sku     @relation(fields: [skuId], references: [id])

  @@unique([skuId, value])
}

model Box {
  id        String          @id @default(uuid())
  clientId  String
  zoneId    String?
  palletId  String?
  code      String
  status    String          @default("active")
  client    Client          @relation(fields: [clientId], references: [id])
  zone      Zone?           @relation(fields: [zoneId], references: [id])
  pallet    Pallet?         @relation(fields: [palletId], references: [id])
  movements StockMovement[]
  balances  StockBalance[]
  productMarks ProductMark[]

  @@unique([clientId, code])
}

model Pallet {
  id       String         @id @default(uuid())
  clientId String
  zoneId   String?
  code     String
  status   String         @default("active")
  client   Client         @relation(fields: [clientId], references: [id])
  zone     Zone?          @relation(fields: [zoneId], references: [id])
  boxes    Box[]
  balances StockBalance[]

  @@unique([clientId, code])
}

model StockMovement {
  id             String       @id @default(uuid())
  clientId       String
  skuId          String
  boxId          String?
  palletId       String?
  type           MovementType
  status         StockStatus
  quantity       Int
  sourceDocument String?
  idempotencyKey String?      @unique
  comment        String?
  client         Client       @relation(fields: [clientId], references: [id])
  sku            Sku          @relation(fields: [skuId], references: [id])
  box            Box?         @relation(fields: [boxId], references: [id])
  productMarks   ProductMark[]
  createdAt      DateTime     @default(now())

  @@index([clientId, skuId, status])
  @@index([boxId])
}

model ProductMark {
  id              String         @id @default(uuid())
  clientId        String
  skuId           String
  boxId           String?
  stockMovementId String?
  value           String
  sourceDocument  String?
  sourceRow       Int?
  status          StockStatus    @default(AVAILABLE)
  client          Client         @relation(fields: [clientId], references: [id])
  sku             Sku            @relation(fields: [skuId], references: [id])
  box             Box?           @relation(fields: [boxId], references: [id])
  stockMovement   StockMovement? @relation(fields: [stockMovementId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([clientId, value])
  @@index([clientId, skuId, status])
  @@index([boxId])
}

model StockBalance {
  id         String      @id @default(uuid())
  balanceKey String      @unique
  clientId   String
  skuId      String
  boxId      String?
  palletId   String?
  status     StockStatus
  quantity   Int
  sku        Sku         @relation(fields: [skuId], references: [id])
  box        Box?        @relation(fields: [boxId], references: [id])
  pallet     Pallet?     @relation(fields: [palletId], references: [id])
  updatedAt  DateTime    @updatedAt

  @@index([clientId, skuId, status])
  @@index([boxId])
}

model ClientRequest {
  id               String                     @id @default(uuid())
  clientId         String
  type             ClientRequestType
  status           ClientRequestStatus        @default(SUBMITTED)
  priority         ClientRequestPriority      @default(NORMAL)
  title            String
  comment          String?
  contactName      String?
  contactPhone     String?
  destinationCity  String?
  deliveryAddress  String?
  desiredDate      DateTime?
  managerComment   String?
  createdByUserId  String?
  assignedToUserId String?
  client           Client                     @relation(fields: [clientId], references: [id])
  createdBy        User?                      @relation("ClientRequestCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo       User?                      @relation("ClientRequestAssignedTo", fields: [assignedToUserId], references: [id])
  items            ClientRequestItem[]
  files            ClientRequestFile[]
  notifications    ClientNotification[]
  comments         ClientRequestComment[]
  events           ClientRequestEvent[]
  packages         ClientRequestPackage[]
  pickWaveRequests PickWaveRequest[]
  billingCharges   BillingCharge[]
  deliveryRequests LogisticsDeliveryRequest[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([clientId, status, createdAt])
  @@index([type, status])
  @@index([createdByUserId])
  @@index([assignedToUserId])
}

model ClientRequestItem {
  id           String                     @id @default(uuid())
  requestId    String
  skuId        String?
  barcode      String?
  name         String?
  quantity     Int
  comment      String?
  request      ClientRequest              @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sku          Sku?                       @relation(fields: [skuId], references: [id])
  packageItems ClientRequestPackageItem[]

  @@index([requestId])
  @@index([skuId])
}

model PickWave {
  id                   String            @id @default(uuid())
  waveNumber           String            @unique
  status               PickWaveStatus    @default(PLANNED)
  comment              String?
  createdByUserId      String?
  assignedPickerUserId String?
  createdBy            User?             @relation("PickWaveCreatedBy", fields: [createdByUserId], references: [id])
  assignedPicker       User?             @relation("PickWaveAssignedPicker", fields: [assignedPickerUserId], references: [id])
  requests             PickWaveRequest[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([createdByUserId])
  @@index([assignedPickerUserId])
}

model PickWaveRequest {
  waveId    String
  requestId String
  status    PickWaveRequestStatus @default(PLANNED)
  result    Json?
  pickedAt  DateTime?
  wave      PickWave              @relation(fields: [waveId], references: [id], onDelete: Cascade)
  request   ClientRequest         @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@id([waveId, requestId])
  @@index([requestId])
  @@index([status])
}

model ClientRequestPackage {
  id              String                     @id @default(uuid())
  requestId       String
  clientId        String
  packageCode     String
  packageType     String?
  weightGrams     Int?
  lengthCm        Decimal?                   @db.Decimal(10, 2)
  widthCm         Decimal?                   @db.Decimal(10, 2)
  heightCm        Decimal?                   @db.Decimal(10, 2)
  comment         String?
  createdByUserId String?
  request         ClientRequest              @relation(fields: [requestId], references: [id], onDelete: Cascade)
  client          Client                     @relation(fields: [clientId], references: [id])
  createdBy       User?                      @relation("ClientRequestPackageCreatedBy", fields: [createdByUserId], references: [id])
  items           ClientRequestPackageItem[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@unique([requestId, packageCode])
  @@index([clientId, createdAt])
  @@index([createdByUserId])
}

model ClientRequestPackageItem {
  id            String               @id @default(uuid())
  packageId     String
  requestItemId String
  skuId         String?
  barcode       String?
  quantity      Int
  package       ClientRequestPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  requestItem   ClientRequestItem    @relation(fields: [requestItemId], references: [id], onDelete: Cascade)
  sku           Sku?                 @relation(fields: [skuId], references: [id])

  @@index([packageId])
  @@index([requestItemId])
  @@index([skuId])
}

model ClientRequestFile {
  id               String        @id @default(uuid())
  requestId        String
  clientId         String
  fileName         String
  mimeType         String
  sizeBytes        Int
  content          Bytes
  uploadedByUserId String?
  request          ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  client           Client        @relation(fields: [clientId], references: [id])
  uploadedBy       User?         @relation("ClientRequestFileUploadedBy", fields: [uploadedByUserId], references: [id])
  createdAt        DateTime      @default(now())

  @@index([requestId, createdAt])
  @@index([clientId, createdAt])
  @@index([uploadedByUserId])
}

model ClientRequestComment {
  id           String        @id @default(uuid())
  requestId    String
  clientId     String
  authorUserId String?
  body         String
  isInternal   Boolean       @default(false)
  request      ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id])
  author       User?         @relation("ClientRequestCommentAuthor", fields: [authorUserId], references: [id])
  createdAt    DateTime      @default(now())

  @@index([requestId, createdAt])
  @@index([clientId, createdAt])
  @@index([authorUserId])
}

model ClientRequestEvent {
  id              String                 @id @default(uuid())
  requestId       String
  clientId        String
  eventType       ClientRequestEventType
  title           String
  body            String?
  statusFrom      ClientRequestStatus?
  statusTo        ClientRequestStatus?
  createdByUserId String?
  request         ClientRequest          @relation(fields: [requestId], references: [id], onDelete: Cascade)
  client          Client                 @relation(fields: [clientId], references: [id])
  createdBy       User?                  @relation("ClientRequestEventCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime               @default(now())

  @@index([requestId, createdAt])
  @@index([clientId, createdAt])
  @@index([eventType, createdAt])
  @@index([createdByUserId])
}

model ClientNotification {
  id              String                     @id @default(uuid())
  clientId        String
  requestId       String?
  title           String
  body            String?
  severity        ClientNotificationSeverity @default(INFO)
  isRead          Boolean                    @default(false)
  readAt          DateTime?
  createdByUserId String?
  client          Client                     @relation(fields: [clientId], references: [id])
  request         ClientRequest?             @relation(fields: [requestId], references: [id], onDelete: SetNull)
  createdBy       User?                      @relation("ClientNotificationCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime                   @default(now())

  @@index([clientId, isRead, createdAt])
  @@index([requestId])
  @@index([createdByUserId])
}

model ClientNotificationPreference {
  id              String                  @id @default(uuid())
  clientId        String
  eventType       ClientNotificationEvent
  isEnabled       Boolean                 @default(true)
  updatedByUserId String?
  client          Client                  @relation(fields: [clientId], references: [id])
  updatedBy       User?                   @relation("ClientNotificationPreferenceUpdatedBy", fields: [updatedByUserId], references: [id])
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([clientId, eventType])
  @@index([clientId])
  @@index([updatedByUserId])
}

model BillingService {
  id              String          @id @default(uuid())
  code            String          @unique
  name            String
  unit            BillingUnit     @default(SERVICE)
  defaultPriceRub Decimal?        @db.Decimal(12, 2)
  isActive        Boolean         @default(true)
  charges         BillingCharge[]
  clientPrices    ClientBillingService[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ClientBillingService {
  id              String              @id @default(uuid())
  clientId        String
  serviceId       String
  priceRub        Decimal             @db.Decimal(12, 2)
  taxMode         BillingPriceTaxMode  @default(INCLUDED)
  isActive        Boolean             @default(true)
  comment         String?
  updatedByUserId String?
  client          Client              @relation(fields: [clientId], references: [id])
  service         BillingService      @relation(fields: [serviceId], references: [id])
  updatedBy       User?               @relation("ClientBillingServiceUpdatedBy", fields: [updatedByUserId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([clientId, serviceId])
  @@index([clientId, isActive])
  @@index([serviceId])
  @@index([updatedByUserId])
}

model BillingCharge {
  id               String                     @id @default(uuid())
  clientId         String
  serviceId        String?
  requestId        String?
  description      String
  unit             BillingUnit                @default(SERVICE)
  quantity         Decimal                    @db.Decimal(12, 3)
  unitPriceRub     Decimal                    @db.Decimal(12, 2)
  totalRub         Decimal                    @db.Decimal(14, 2)
  status           BillingChargeStatus        @default(DRAFT)
  serviceDate      DateTime                   @default(now())
  source           BillingChargeSource        @default(MANUAL)
  sourceKey        String?                    @unique
  metadata         Json?
  comment          String?
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  client           Client                     @relation(fields: [clientId], references: [id])
  service          BillingService?            @relation(fields: [serviceId], references: [id])
  request          ClientRequest?             @relation(fields: [requestId], references: [id])
  createdBy        User?                      @relation("BillingChargeCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy       User?                      @relation("BillingChargeApprovedBy", fields: [approvedByUserId], references: [id])
  invoiceItems     BillingInvoiceItem[]
  deliveryRequests LogisticsDeliveryRequest[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([clientId, status, serviceDate])
  @@index([requestId])
  @@index([serviceId])
  @@index([approvedByUserId])
  @@index([source, serviceDate])
}

model BillingInvoice {
  id              String               @id @default(uuid())
  number          String               @unique
  clientId        String
  periodFrom      DateTime
  periodTo        DateTime
  dueDate         DateTime?
  status          BillingInvoiceStatus @default(DRAFT)
  totalRub        Decimal              @db.Decimal(14, 2)
  paidRub         Decimal              @default(0) @db.Decimal(14, 2)
  issuedAt        DateTime?
  paidAt          DateTime?
  comment         String?
  createdByUserId String?
  client          Client               @relation(fields: [clientId], references: [id])
  createdBy       User?                @relation("BillingInvoiceCreatedBy", fields: [createdByUserId], references: [id])
  items           BillingInvoiceItem[]
  payments        BillingPayment[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([clientId, status, periodFrom])
  @@index([periodTo])
  @@index([createdByUserId])
}

model BillingInvoiceItem {
  id           String         @id @default(uuid())
  invoiceId    String
  chargeId     String?
  description  String
  unit         BillingUnit    @default(SERVICE)
  quantity     Decimal        @db.Decimal(12, 3)
  unitPriceRub Decimal        @db.Decimal(12, 2)
  totalRub     Decimal        @db.Decimal(14, 2)
  serviceDate  DateTime
  invoice      BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  charge       BillingCharge? @relation(fields: [chargeId], references: [id])

  @@index([invoiceId])
  @@index([chargeId])
}

model BillingPayment {
  id              String               @id @default(uuid())
  invoiceId       String
  clientId        String
  amountRub       Decimal              @db.Decimal(14, 2)
  paidAt          DateTime             @default(now())
  method          String?
  reference       String?
  comment         String?
  status          BillingPaymentStatus @default(RECORDED)
  createdByUserId String?
  invoice         BillingInvoice       @relation(fields: [invoiceId], references: [id])
  client          Client               @relation(fields: [clientId], references: [id])
  createdBy       User?                @relation("BillingPaymentCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([invoiceId, status])
  @@index([clientId, paidAt])
  @@index([createdByUserId])
}

model OwnCompany {
  id                     String                  @id @default(uuid())
  shortName              String
  fullName               String
  inn                    String
  kpp                    String?
  ogrn                   String?
  legalAddress           String?
  bankName               String?
  bankBik                String?
  bankAccount            String?
  correspondentAccount   String?
  paymentCode            String?
  paymentPurposeCode     String?
  isDefault              Boolean                 @default(false)
  isActive               Boolean                 @default(true)
  comment                String?
  bankAccounts           OwnCompanyBankAccount[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([isDefault, isActive])
  @@index([inn])
}

model OwnCompanyBankAccount {
  id                   String     @id @default(uuid())
  companyId            String
  bankName             String
  bankBik              String
  bankAccount          String
  correspondentAccount String?
  isDefault            Boolean    @default(false)
  comment              String?
  company              OwnCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([companyId])
}

model LogisticsTariffSet {
  id               String                     @id @default(uuid())
  name             String
  sourceFile       String?
  note             String?
  activeFrom       DateTime?
  activeTo         DateTime?
  directions       LogisticsDirection[]
  deliveryRequests LogisticsDeliveryRequest[]
  createdAt        DateTime                   @default(now())
}

model LogisticsDirection {
  id          String               @id @default(uuid())
  tariffSetId String
  origin      String
  destination String
  note        String?
  pricingMode LogisticsPricingMode @default(MANUAL_REVIEW)
  tariffSet   LogisticsTariffSet   @relation(fields: [tariffSetId], references: [id])
  tiers       LogisticsRateTier[]

  @@index([tariffSetId, origin, destination])
}

model LogisticsRateTier {
  id          String               @id @default(uuid())
  directionId String
  label       String
  minPallets  Int?
  maxPallets  Int?
  maxBoxes    Int?
  pricingMode LogisticsPricingMode @default(MANUAL_REVIEW)
  priceRub    Decimal              @db.Decimal(12, 2)
  direction   LogisticsDirection   @relation(fields: [directionId], references: [id])

  @@index([directionId])
}

model LogisticsCarrier {
  id          String          @id @default(uuid())
  name        String
  phone       String?
  contactName String?
  comment     String?
  isActive    Boolean         @default(true)
  trips       LogisticsTrip[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([isActive, name])
}

model LogisticsTrip {
  id            String                     @id @default(uuid())
  code          String                     @unique
  carrierId     String?
  plannedDate   DateTime?
  vehicleNumber String?
  driverName    String?
  driverPhone   String?
  status        LogisticsTripStatus        @default(PLANNED)
  comment       String?
  carrier       LogisticsCarrier?          @relation(fields: [carrierId], references: [id])
  deliveries    LogisticsDeliveryRequest[]
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([status, plannedDate])
  @@index([carrierId])
}

model LogisticsDeliveryRequest {
  id                   String                  @id @default(uuid())
  clientId             String
  requestId            String?
  tariffSetId          String?
  billingChargeId      String?
  tripId               String?
  origin               String
  destination          String
  boxes                Int?
  pallets              Int?
  desiredShipDate      DateTime?
  plannedShipDate      DateTime?
  status               LogisticsDeliveryStatus @default(REQUESTED)
  estimatedTotalRub    Decimal?                @db.Decimal(14, 2)
  requiresManualReview Boolean                 @default(false)
  comment              String?
  managerComment       String?
  createdByUserId      String?
  client               Client                  @relation(fields: [clientId], references: [id])
  request              ClientRequest?          @relation(fields: [requestId], references: [id])
  tariffSet            LogisticsTariffSet?     @relation(fields: [tariffSetId], references: [id])
  billingCharge        BillingCharge?          @relation(fields: [billingChargeId], references: [id])
  trip                 LogisticsTrip?          @relation(fields: [tripId], references: [id])
  createdBy            User?                   @relation("LogisticsDeliveryCreatedBy", fields: [createdByUserId], references: [id])
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([clientId, status, createdAt])
  @@index([requestId])
  @@index([billingChargeId])
  @@index([tariffSetId])
  @@index([tripId])
}

model TsdOperation {
  id                String             @id @default(uuid())
  deviceId          String
  operationKey      String             @unique
  operationType     String
  payload           Json
  status            TsdOperationStatus @default(ACCEPTED)
  serverMessage     String?
  reviewReason      TsdReviewReason?
  resolutionMessage String?
  reviewAction      TsdReviewAction?
  reviewComment     String?
  reviewedByUserId  String?
  reviewedBy        User?              @relation("TsdOperationReviewedBy", fields: [reviewedByUserId], references: [id])
  reviewedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([deviceId])
  @@index([reviewReason])
  @@index([reviewedAt])
  @@index([reviewedByUserId])
}

model TsdDevice {
  id          String          @id @default(uuid())
  code        String          @unique
  name        String
  secretHash  String
  status      TsdDeviceStatus @default(ACTIVE)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  lastLoginAt DateTime?
  lastSeenAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

model PrintJob {
  id          String    @id @default(uuid())
  printerCode String
  labelType   String
  payload     Json
  tspl        String
  status      String    @default("queued")
  attempts    Int       @default(0)
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([printerCode, status, createdAt])
}

model PrintPrinter {
  id             String    @id @default(uuid())
  code           String    @unique
  groupCode      String    @default("DEFAULT")
  name           String
  connectionType String    @default("dry_run")
  host           String?
  port           Int?
  isActive       Boolean   @default(true)
  autoProcess    Boolean   @default(true)
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([groupCode, isActive, autoProcess])
  @@index([isActive, autoProcess])
}

model LabelTemplate {
  id          String                 @id @default(uuid())
  code        String                 @unique
  name        String
  type        LabelTemplateType
  description String?
  widthMm     Int                    @default(80)
  heightMm    Int                    @default(50)
  tspl        String
  version     Int                    @default(1)
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  versions    LabelTemplateVersion[]

  @@index([type, isActive])
}

model LabelTemplateVersion {
  id           String            @id @default(uuid())
  templateId   String
  version      Int
  code         String
  name         String
  type         LabelTemplateType
  description  String?
  widthMm      Int
  heightMm     Int
  tspl         String
  isActive     Boolean
  changeReason String?
  createdAt    DateTime          @default(now())
  template     LabelTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  payload   Json?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
